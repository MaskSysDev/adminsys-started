    "sonner": "2.0.7",
    "tailwind-merge": "3.3.1",
    "zod": "4.0.17"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
